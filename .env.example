# ==========================================
# Public — được expose ra client (prefix NUXT_PUBLIC_)
# ==========================================
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NUXT_PUBLIC_APP_NAME=LongHieu Chanel

# ==========================================
# Private — chỉ dùng phía server
# ==========================================
# Lấy key tại https://aistudio.google.com/apikey
NUXT_GEMINI_API_KEY=
NUXT_API_SECRET=

# ==========================================
# Runtime
# ==========================================
NODE_ENV=development
NITRO_PORT=3000
NITRO_HOST=0.0.0.0
